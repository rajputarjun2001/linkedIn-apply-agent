# LinkedIn manual session auth (no credentials — connect via dashboard)
LINKEDIN_CONNECT_TIMEOUT=300

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# Job Search Configuration
JOB_KEYWORDS=Software Engineer,Frontend Developer,React Developer, Software Developer
LOCATIONS=India
MIN_MATCH_SCORE=70
DISCOVERY_MATCH_LIMIT=10

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_HOURS=1

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=false
